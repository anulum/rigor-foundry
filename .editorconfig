# RigorFoundry — Editor configuration

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.py]
indent_style = space
indent_size = 4

[*.{json,toml,yaml,yml}]
indent_style = space
indent_size = 2

[Makefile]
indent_style = tab
